# 信聘后端 - 环境变量配置

NODE_ENV=development
PORT=3000

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=xinpin2026
MYSQL_DATABASE=xinpin

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/xinpin

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Elasticsearch
ES_NODE=http://127.0.0.1:9200
ES_USER=elastic
ES_PASSWORD=

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 短信服务
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=信聘

# OSS
OSS_PROVIDER=aliyun
OSS_BUCKET=xinpin
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
